# Local-dev defaults for the standalone DogeClaw stack.
# Copy to .env and tweak as needed: cp .env.example .env

# --- Postgres ---
POSTGRES_USER=dogeclaw
POSTGRES_PASSWORD=changeme
POSTGRES_DB=dogeclaw
# Host port to expose postgres on (override if 5434 collides)
POSTGRES_HOST_PORT=5434

# --- DogeClaw web UI ---
DOGECLAW_PORT=3000
DOGECLAW_WEB_USER=admin
DOGECLAW_WEB_PASSWORD=changeme
# Generate with: openssl rand -hex 32
DOGECLAW_WEB_SECRET=dogeclaw-change-me

# --- Ollama (optional, for local LLMs) ---
# Leave blank if you only use cloud models (OpenRouter / Google Gemini),
# configured at runtime via the admin UI.
# Example for a separately-running local ollama:
#   DOGECLAW_OLLAMA_URL=http://host.docker.internal:11434
DOGECLAW_OLLAMA_URL=

# --- Telegram (optional) ---
# 'polling' for local dev (no public URL needed), 'webhook' in prod.
DOGECLAW_TELEGRAM_MODE=polling
DOGECLAW_WEBHOOK_URL=

# --- Dev fixtures (optional) ---
# Consumed only by `docker exec dogeclaw npm run seed`, which idempotently
# loads a starter model + skills + agents + telegram channel so a fresh
# stack isn't empty. Each variable is independent — leave one blank and
# its fixture is skipped.
#
# Gemini API key (get one at https://aistudio.google.com/apikey).
DOGECLAW_FIXTURE_GEMINI_API_KEY=
# Telegram bot token from BotFather.
DOGECLAW_FIXTURE_TELEGRAM_BOT_TOKEN=
